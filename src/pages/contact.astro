---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
---

<Base
  activePage="contact"
  title="Contact — Kevin Minn"
  description="For founder inquiries, literary representation, or anything in between."
>
  <main class="page">
    <div class="page-inner">
      <div class="eyebrow">Contact</div>
      <h1>Say <em>hello.</em></h1>
      <p class="lede">
        For founder inquiries, literary representation, or anything in between.
      </p>
      <div class="contact-list">
        <a href="mailto:hello@kevinminn.com" class="contact-item">
          <span class="lbl">Personal</span>
          <span class="val">hello@kevinminn.com</span>
        </a>
        <a href="mailto:kevin.minn@vindicara.io" class="contact-item">
          <span class="lbl">Vindicara</span>
          <span class="val">kevin.minn@vindicara.io</span>
        </a>
        <a href="mailto:press@kevinminn.com" class="contact-item">
          <span class="lbl">Press</span>
          <span class="val">press@kevinminn.com</span>
        </a>
      </div>
      <a href="/" class="back" data-interstitial-link>&larr; Back to welcome</a>
    </div>
    <Footer />
  </main>
</Base>

<style>
  .page {
    padding: 140px 80px 40px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .page-inner {
    flex: 1;
    max-width: 720px;
  }
  .eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: #b4543e;
    margin-bottom: 28px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: #b4543e;
  }
  h1 {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(48px, 6vw, 88px);
    line-height: 1;
    letter-spacing: -0.035em;
    color: #1c1a17;
    margin-bottom: 32px;
  }
  h1 em {
    font-style: italic;
    font-weight: 400;
    color: #b4543e;
  }
  .lede {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(18px, 1.4vw, 21px);
    line-height: 1.55;
    color: #4a453d;
    max-width: 540px;
    margin-bottom: 40px;
  }
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 56px;
  }
  .contact-item {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid #e8e1d2;
    text-decoration: none;
    color: #1c1a17;
    align-items: baseline;
    transition: padding 0.25s ease;
  }
  .contact-item:hover {
    padding-left: 12px;
  }
  .contact-item .lbl {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: #8a8479;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .contact-item .val {
    font-family: 'Fraunces', serif;
    font-size: 20px;
    color: #1c1a17;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .contact-item:hover .val {
    color: #b4543e;
    font-style: italic;
  }
  .back {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #4a453d;
    text-decoration: none;
    transition: color 0.2s;
  }
  .back:hover {
    color: #b4543e;
  }
  @media (max-width: 980px) {
    .page {
      padding: 100px 32px 32px;
    }
    .contact-item {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
  @media (max-width: 768px) {
    .page {
      padding: 88px 20px 24px;
    }
    h1 {
      font-size: clamp(36px, 10vw, 56px);
    }
    .lede {
      font-size: 16px;
    }
    .contact-item .val {
      font-size: 17px;
    }
  }
</style>
