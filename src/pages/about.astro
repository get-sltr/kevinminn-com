---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
---

<Base
  activePage="about"
  title="About — Kevin Minn"
  description="Born in Burma. Built in Los Angeles. Founder. Author."
>
  <main class="page">
    <div class="page-inner">
      <div class="eyebrow">About</div>
      <h1>The <em>person.</em></h1>
      <p class="lede">
        Born in Burma. Built in Los Angeles. Founder of Vindicara. Author of a forthcoming memoir.
        This page is being built.
      </p>
      <a href="/" class="back" data-interstitial-link>&larr; Back to welcome</a>
    </div>
    <Footer />
  </main>
</Base>

<style>
  .page {
    padding: 140px 80px 40px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .page-inner {
    flex: 1;
    max-width: 720px;
  }
  .eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: #b4543e;
    margin-bottom: 28px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: #b4543e;
  }
  h1 {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(48px, 6vw, 88px);
    line-height: 1;
    letter-spacing: -0.035em;
    color: #1c1a17;
    margin-bottom: 32px;
  }
  h1 em {
    font-style: italic;
    font-weight: 400;
    color: #b4543e;
  }
  .lede {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(18px, 1.4vw, 21px);
    line-height: 1.55;
    color: #4a453d;
    max-width: 540px;
    margin-bottom: 40px;
  }
  .back {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #4a453d;
    text-decoration: none;
    transition: color 0.2s;
  }
  .back:hover {
    color: #b4543e;
  }
  @media (max-width: 980px) {
    .page {
      padding: 100px 32px 32px;
    }
  }
  @media (max-width: 768px) {
    .page {
      padding: 88px 20px 24px;
    }
    h1 {
      font-size: clamp(36px, 10vw, 56px);
    }
    .lede {
      font-size: 16px;
    }
  }
</style>
